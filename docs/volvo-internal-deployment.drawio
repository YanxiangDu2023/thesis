        <mxCell id="title" value="Volvo Internal Deployment Blueprint&#xa;React + FastAPI + CSV/Data Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#002b49;fontColor=#ffffff;strokeColor=#001a2d;fontSize=20;fontStyle=1;" vertex="1" parent="1">
